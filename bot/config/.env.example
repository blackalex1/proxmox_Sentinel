BOT_TOKEN=ваш_токен_телеграм_бота
PROXMOX_HOST=your_proxmox_ip:8006
PROXMOX_USER=root@pam

# Данные для доступа через API Token (Proxmox -> Datacenter -> Permissions -> API Tokens)
PROXMOX_TOKEN_ID=root@pam!MyToken
PROXMOX_TOKEN_SECRET=ваш_секретный_код_токена

# Отключение проверки SSL-сертификата (если используете самоподписанный)
PROXMOX_VERIFY_SSL=False

# ID администраторов Telegram (через запятую) которым разрешен доступ к боту
ADMIN_IDS=123456789,987654321


# Путь к папке с плейбуками Ansible (например: C:/Users/username/ansible или /opt/ansible)
# Можно оставить пустым, тогда бот будет искать .yml файлы в папке проекта
ANSIBLE_PLAYBOOKS_DIR=./ansible

# Прокси для Telegram (HTTP или SOCKS5), оставьте пустым если не нужно
# Пример: http://login:pass@12.34.56.78:8080 или socks5://12.34.56.78:1080
PROXY_URL=

# Автоматическая ротация бесплатных SOCKS5 прокси при сбое основного прокси (True/False)
# Бот сам скачает, выберет быстрейший прокси и горячо подменит сессию на лету,
# а также продолжит проверять ваш основной Shadowsocks и вернется на него, когда тот оживет.
ENABLE_FREE_PROXY_ROTATION=False

# Альтернативный Bot API сервер (например, приватный реверс-прокси на Cloudflare Workers)
# Оставьте пустым, если используете стандартный сервер Telegram
TELEGRAM_API_SERVER=


# ==========================================
# Мониторинг LXC Контейнеров
# ==========================================
# Пороги предупреждений по ресурсам (в %)
MONITOR_LXC_CPU=90
MONITOR_LXC_RAM=90
MONITOR_LXC_DISK=90

# Белый список портов (не отправлять алерты о подключениях на эти порты, через запятую)
MONITOR_LXC_PORTS_WHITELIST=80,443,53,123

# Особо чувствительные порты (алерты о подключениях приходят мгновенно, через запятую)
MONITOR_LXC_PORTS_SENSITIVE=22,3389,3306,5432,27017,8006

# Доверенные IP-адреса администраторов (через запятую), которые не будут спамить алертами при доступе к 8006 и 22
TRUSTED_ADMIN_IPS=your_admin_ip

# Идентификатор контейнера с VPN
VPN_VMID=101
# Входящие порты VPN-сервиса (через запятую)
MONITOR_LXC_VPN_PORTS=51820,1194

# Тайм-аут отсутствия активности для VPN-клиентов (в секундах), по истечении которого считается, что клиент отключился
VPN_OFFLINE_TIMEOUT=1800

# Список пользователей VPN (через запятую), для которых не нужно присылать уведомления о подключении/отключении
VPN_IGNORE_USERS=monitoring_bot

# Отправлять ли предупреждения (WARNING) о нетипичных исходящих портах транзитных клиентов VPN (True/False)
ALERT_VPN_CLIENT_UNUSUAL_PORTS=False

# Период группировки (дебаунсинга) быстрых подключений/отключений VPN клиентов (в секундах)
# Все события в этом интервале будут отправлены одним красивым сообщением-сводкой
VPN_ALERT_DEBOUNCE_SEC=3.0

# ==========================================
# Мониторинг удаленного сервера (Target VPS)
# ==========================================
REMOTE_MONITOR_ENABLE=False

# Список ключей (комментариев или отпечатков) для игнорирования успешных SSH входов на удаленных VPS (через запятую)
# По умолчанию "bot@bot", чтобы бот не слал алерты на собственные SSH-сессии для мониторинга логов
REMOTE_MONITOR_IGNORE_KEYS=bot@bot

# Список IP-адресов для игнорирования успешных SSH входов на удаленных VPS (через запятую)
REMOTE_MONITOR_IGNORE_IPS=

# Белый список процессов IPS, которые запрещено принудительно завершать (kill -9) (через запятую)
IPS_PROCESS_WHITELIST=
# Белый список LXC контейнеров для IPS, которым разрешены любые исходящие соединения (через запятую)
IPS_LXC_WHITELIST=100
REMOTE_SERVER_IP=your_vps_ip
REMOTE_SERVER_USER=root
REMOTE_SERVER_SSH_KEY=config/id_rsa_remote

# ==========================================
# Мониторинг трафика роутера через SSH
# ==========================================
ROUTER_MONITOR_ENABLE=False

# Режим мониторинга трафика на роутере:
# - "conntrack" — SSH-стрим таблицы conntrack ядра Linux (0% нагрузки, видит все сетевые соединения роутера)
# - "iptables" — SSH-стрим логов IPTables роутера (нагрузка минимальна, требует правил логирования)
ROUTER_MONITOR_MODE=conntrack

# Автоматический бан нарушителей на роутере (True/False)
ROUTER_AUTO_BAN=False
ROUTER_MAX_VIOLATIONS=3

# Настройки SSH для роутера
ROUTER_SSH_HOST=192.168.1.1
ROUTER_SSH_PORT=22
ROUTER_SSH_USER=root
ROUTER_SSH_PASSWORD=your_router_password
ROUTER_SSH_KEY=config/id_rsa_router
ROUTER_TYPE=openwrt

# ==========================================
# Интеграция с Spectre Panel (Ручные настройки)
# ==========================================
# JSON-массив с параметрами Spectre Panel. Будет использоваться наряду с автообнаружением в Proxmox/VPS.
# Формат: [{"name": "Node Name", "url": "http://IP:Port", "token": "API_TOKEN", "secret_path": "ui"}, ...]
SPECTRE_PANELS='[]'

